generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  userID        Int         @id @default(autoincrement())
  microsoft_sub String?     @unique
  userNome      String?     @db.VarChar(255)
  userEmail     String      @unique @db.VarChar(255)
  userSenha     String?     @db.VarChar(255)
  criadoDate    DateTime    @default(now())
  tipoUser      TipoUser    @default(DOCENTE)
  statusUser    StatusConta @default(CONVIDADA)
  fotoUrl       String?
  adm           ADM?
  docente       Docente?
  ti            TI?


  chamadasAbertas   ChamadaTecnica[] @relation("DocenteChamada")
  chamadasAtendidas ChamadaTecnica[] @relation("TecnicoChamada")

  @@index([userID])
  @@index([userNome])
  @@index([tipoUser])
}

model TI {
  tiID      Int     @id @default(autoincrement())
  fk_userID Int     @unique
  usuario   Usuario @relation(fields: [fk_userID], references: [userID])
}

model Docente {
  docenteID Int     @id @default(autoincrement())
  fk_userID Int     @unique
  usuario   Usuario @relation(fields: [fk_userID], references: [userID])
}

model ADM {
  admID     Int     @id @default(autoincrement())
  fk_userID Int     @unique
  usuario   Usuario @relation(fields: [fk_userID], references: [userID])
}

model Sala {
  idSala              Int                  @id @default(autoincrement())
  nomeSala            String               @unique @db.VarChar(255)
  tipoSala            TipoSala             @default(COMUN)
  disponibilidadeSala Boolean
  fotoSala            String?              @db.VarChar(255)
  qtdeSala            Int
  capacidadeAlunos    Int?
  inventario          Inventario?
  agendamentos        Agendamento[]
  historicos          HistoricoInventario[]

  chamadas            ChamadaTecnica[]

  @@index([tipoSala])
  @@index([idSala])
  @@index([disponibilidadeSala])
}

model Inventario {
  idInventario     Int                      @id @default(autoincrement())
  salaId           Int                      @unique
  sala             Sala                     @relation(fields: [salaId], references: [idSala], onDelete: Cascade)
  dispositivos     InventarioDispositivo[]
  tecnologias      InventarioTecnologia[]
  statusInventario StatusInventario         @default(ATIVO)
  criadoEm         DateTime                 @default(now())
  atualizadoEm     DateTime                 @updatedAt
  historicos       HistoricoInventario[]

  @@index([salaId])
  @@index([statusInventario])
}

model Dispositivo {
  idDispositivo         Int                      @id @default(autoincrement())
  nomeDispositivo       String                   @db.VarChar(255)
  tipoDispositivo       DispositvoTipo
  patrimonio            String?                  @unique @db.VarChar(7)
  statusDispositivo     StatusDispositivo        @default(ATIVO)
  dataCriacao           DateTime                 @default(now())
  dataAtualizacao       DateTime                 @updatedAt
  inventarios           InventarioDispositivo[]
  historicos            DispositivoHistorico[]

  chamadas              ChamadaTecnica[]

  @@index([tipoDispositivo])
  @@index([statusDispositivo])
}

model InventarioDispositivo {
  id          Int         @id @default(autoincrement())
  inventarioId Int
  dispositivoId Int
  inventario  Inventario  @relation(fields: [inventarioId], references: [idInventario], onDelete: Cascade)
  dispositivo Dispositivo @relation(fields: [dispositivoId], references: [idDispositivo], onDelete: Cascade)
  quantidade  Int         @default(1)

  @@unique([inventarioId, dispositivoId])
  @@index([inventarioId])
  @@index([dispositivoId])
}

model Tecnologia {
  idTecnologia      Int                      @id @default(autoincrement())
  nomeTecnologia    String                   @unique @db.VarChar(255)
  descricao         String?                  @db.VarChar(500)
  dataCriacao       DateTime                 @default(now())
  inventarios       InventarioTecnologia[]

  @@index([nomeTecnologia])
}

model InventarioTecnologia {
  id            Int          @id @default(autoincrement())
  inventarioId  Int
  tecnologiaId  Int
  inventario    Inventario   @relation(fields: [inventarioId], references: [idInventario], onDelete: Cascade)
  tecnologia    Tecnologia   @relation(fields: [tecnologiaId], references: [idTecnologia], onDelete: Cascade)

  @@unique([inventarioId, tecnologiaId])
  @@index([inventarioId])
  @@index([tecnologiaId])
}

model HistoricoInventario {
  idHistorico       Int          @id @default(autoincrement())
  inventarioId      Int
  salaId            Int
  tipoAlteracao     TipoAlteracao
  descricaoAlteracao String?      @db.VarChar(500)
  usuarioId         Int?
  dataCriacao       DateTime     @default(now())
  inventario        Inventario   @relation(fields: [inventarioId], references: [idInventario], onDelete: Cascade)
  sala              Sala         @relation(fields: [salaId], references: [idSala], onDelete: Cascade)

  @@index([inventarioId])
  @@index([salaId])
  @@index([tipoAlteracao])
  @@index([dataCriacao])
}

model DispositivoHistorico {
  idHistorico       Int               @id @default(autoincrement())
  dispositivoId     Int
  tipoAlteracao     TipoAlteracao
  descricaoAlteracao String?           @db.VarChar(500)
  dataCriacao       DateTime          @default(now())
  dispositivo       Dispositivo       @relation(fields: [dispositivoId], references: [idDispositivo], onDelete: Cascade)

  @@index([dispositivoId])
  @@index([tipoAlteracao])
  @@index([dataCriacao])
}

model Agendamento {
  idAgendamento      Int                  @id @default(autoincrement())
  salaId             Int
  usuarioId          Int?
  dataAgendamento    DateTime
  horaInicio         String               @db.VarChar(5)
  horaFim            String               @db.VarChar(5)
  descricao          String?              @db.VarChar(500)
  statusAgendamento  AgendamentoStatus    @default(EM_ESPERA)
  criadoEm           DateTime             @default(now())
  atualizadoEm       DateTime             @updatedAt
  sala               Sala                 @relation(fields: [salaId], references: [idSala], onDelete: Cascade)

  @@index([salaId])
  @@index([dataAgendamento])
  @@index([statusAgendamento])
}



model ChamadaTecnica {
  idChamada         Int           @id @default(autoincrement())
  dataChamada       DateTime      @default(now())
  dataResposta      DateTime?
  anexos            String?       @db.VarChar(255)
  tipoProblema      TipoProblema
  descricao         String        @db.VarChar(255)
  status            ChamadaStatus @default(ABERTO)
  acoesRealizadas   String?       @db.Text
  salaId            Int
  sala              Sala          @relation(fields: [salaId], references: [idSala])
  usuarioId         Int
  usuario           Usuario       @relation("DocenteChamada", fields: [usuarioId], references: [userID])
  tecnicoId         Int?
  tecnico           Usuario?      @relation("TecnicoChamada", fields: [tecnicoId], references: [userID])
  dispositivoId     Int?
  dispositivo       Dispositivo?  @relation(fields: [dispositivoId], references: [idDispositivo])
  dispositivoNome   String?
  patrimonio        String?
  tecnologias       TecnologiaSolicitada[]

  @@map("chamadas_tecnicas")
}

model TecnologiaSolicitada {
  idTecnologia Int           @id @default(autoincrement())
  nome         String
  versao       String
  chamadoId    Int
  chamado      ChamadaTecnica @relation(fields: [chamadoId], references: [idChamada])
}



enum TipoSala {
  COMUN
  LAB
  ARMAZEM
}

enum AgendamentoStatus {
  AGENDADO
  CANCELADO
  EM_ESPERA
}

enum TipoUser {
  DOCENTE
  TI
  ADM
}

enum ChamadaStatus {
  ABERTO
  EM_ATENDIMENTO
  RESOLVIDO
}

enum DispositvoTipo {
  TV
  NOTEBOOK
  DESKTOP
  PROJETOR
}

enum StatusConta {
  DESATIVADA
  ATIVA
  CONVIDADA
}

enum StatusInventario {
  ATIVO
  INATIVO
  MANUTENCAO
}

enum StatusDispositivo {
  ATIVO
  INATIVO
  DANIFICADO
  MANUTENCAO
}

enum TipoAlteracao {
  CRIACAO
  EDICAO
  DELECAO
  ADICIONAR_DISPOSITIVO
  REMOVER_DISPOSITIVO
  ADICIONAR_TECNOLOGIA
  REMOVER_TECNOLOGIA
  ALTERACAO_STATUS
}

enum TipoProblema {
  Hardware
  Software
}